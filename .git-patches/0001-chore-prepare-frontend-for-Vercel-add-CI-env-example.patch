+    @apply status-dot bg-positive animate-pulse;
+  }
+
+  .btn-primary {
+    @apply px-4 py-2 bg-accent text-white font-semibold rounded text-sm hover:bg-accent-hover transition-colors shadow-lg shadow-accent/20;
+  }
+
+  .btn-secondary {
+    @apply px-4 py-2 bg-bg-card border border-border text-text rounded text-sm hover:border-accent/50 transition-colors;
+  }
+
+  .input-field {
+    @apply bg-bg-panel border border-border rounded px-3 py-2 text-sm text-text placeholder-text-tertiary focus:outline-none focus:border-accent/50 transition-colors;
+  }
+
+  .table-header {
+    @apply text-xs font-semibold uppercase tracking-wider text-text-secondary bg-bg-panel px-4 py-2 text-left sticky top-0 z-10;
+  }
+
+  .table-row {
+    @apply border-b border-border/50 hover:bg-bg-hover transition-colors cursor-pointer;
+  }
+
+  .table-row-alt {
+    @apply bg-bg-panel/50;
+  }
+
+  .table-cell {
+    @apply px-4 py-2.5 text-sm;
+  }
+
+  .badge {
+    @apply inline-flex items-center px-2 py-0.5 rounded text-xs font-medium;
+  }
+
+  .badge-positive {
+    @apply badge bg-positive/10 text-positive border border-positive/20;
+  }
+
+  .badge-negative {
+    @apply badge bg-negative/10 text-negative border border-negative/20;
+  }
+
+  .badge-warning {
+    @apply badge bg-warning/10 text-warning border border-warning/20;
+  }
+
+  .badge-accent {
+    @apply badge bg-accent/10 text-accent border border-accent/20;
+  }
+
+  .badge-secondary {
+    @apply badge bg-secondary/10 text-secondary border border-secondary/20;
+  }
+}
+
+@layer utilities {
+  .text-gradient-accent {
+    @apply bg-gradient-to-r from-accent to-accent-hover bg-clip-text text-transparent;
