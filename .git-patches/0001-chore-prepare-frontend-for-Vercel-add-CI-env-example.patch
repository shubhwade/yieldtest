+# 4. ARTIFICIAL INTELLIGENCE & COPILOT
+# Google Gemini API Key - https://aistudio.google.com/
+GEMINI_API_KEY=your_gemini_api_key_here
+
+# OpenRouter rotation model API Key - https://openrouter.ai/
+OPENROUTER_API_KEY=your_openrouter_key_here
+
+# 5. CORE SECURITY & AUTHENTICATION
+# Cryptographic secret for signing JWT access tokens (Change to secure hash)
+JWT_SECRET=yieldlens-production-cryptographic-hash-change-immediately
+JWT_EXPIRATION_HOURS=24
+
+# 6. APPLICATION SERVERS & NETWORKING
+# Flask API Server config
+FLASK_PORT=5000
+FLASK_DEBUG=False
+
+# Next.js Client config
+NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
