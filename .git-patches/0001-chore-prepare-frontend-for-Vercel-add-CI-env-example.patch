+        manual_hhi = sum(w**2 for w in weights)
+        
+        # Using concentration risk function (which normalizes HHI)
+        n = len(weights)
+        min_hhi = 1/n
+        max_hhi = 1.0
+        
+        normalized_hhi = (manual_hhi - min_hhi) / (max_hhi - min_hhi)
