+                for a in articles
+                if cat_lower in [c.lower() for c in a.get("categories", [])]
+            ] or articles  # Fall back to all if filter empties
+
+        articles = articles[:limit]
+
+        # 5. Cache and persist
+        cache.set(cache_key, articles, ttl=self.cache_ttl)
+        self._store_articles(articles)
+
+        return articles
