+        """Mark a telemetry alert as resolved."""
+        try:
+            db = get_db()
+            from bson import ObjectId
+
+            db["telemetry_alerts"].update_one(
+                {"_id": ObjectId(alert_id)}, {"$set": {"resolved": True}}
+            )
+            return True
+        except Exception:
+            return False
