+      - GEMINI_API_KEY=AIzaSyA_zpO7UX5zt4t3Z6_tyNAmB3ifF6mC1RY
+      - ALPHA_VANTAGE_API_KEY=AE11PZPHI2X5SZ09
+      - FLASK_PORT=5000
+      - FLASK_DEBUG=False
+    depends_on:
+      - mongodb
+      - redis
