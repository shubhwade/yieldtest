+    },
+    "corporate": {
+        "name": "Corporate Bond",
+        "typical_yield_range": [4.0, 7.0],
+        "risk_level": "Low to Moderate",
+        "risk_score": 30,
+        "typical_duration": [1, 30],
+        "credit_quality": "BBB to AAA",
