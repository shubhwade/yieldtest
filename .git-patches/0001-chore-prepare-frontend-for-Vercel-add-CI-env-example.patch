+      - "6379:6379"
+    volumes:
+      - redis_data:/data
+
+  # 3. Python Flask API Service
+  backend:
+    build:
+      context: ./backend
+      dockerfile: Dockerfile
+    container_name: yieldlens-backend
+    restart: unless-stopped
+    ports:
