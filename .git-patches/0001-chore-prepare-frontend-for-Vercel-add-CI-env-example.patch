+
+  .grid-pattern {
+    background-image: 
+      linear-gradient(rgba(51, 65, 85, 0.3) 1px, transparent 1px),
+      linear-gradient(90deg, rgba(51, 65, 85, 0.3) 1px, transparent 1px);
+    background-size: 20px 20px;
+  }
+
+  .card-hover {
+    @apply transition-all duration-200 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5;
+  }
+
+  .data-cell {
+    @apply font-mono text-sm tabular-nums;
+  }
+
+  .metric-value {
+    @apply font-mono text-2xl font-bold tracking-tight;
+  }
+
+  .section-title {
+    @apply text-xs font-semibold uppercase tracking-wider text-text-secondary;
+  }
+
+  .panel {
+    @apply bg-bg-card border border-border rounded-lg;
+  }
+
+  .panel-header {
+    @apply px-4 py-3 border-b border-border flex items-center justify-between;
+  }
+
+  .panel-body {
