# ==============================================================================
# YIELDLENS .gitignore — Production Release
# ==============================================================================

# ── Dependencies ──
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
env/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# ── Environment Secrets ──
.env
.env.local
.env.production
.env.staging
.env.*.local
backend/.env

# ── Build Outputs ──
.next/
out/
dist/
build/
*.js.map
tsconfig.tsbuildinfo

# ── IDE & Editor ──
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ── OS Generated ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Database & Persistence ──
*.db
*.sqlite
*.sqlite3
mongodb_data/
dump/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
backend_startup.log
frontend_startup.log

# ── Test & Coverage ──
coverage/
.nyc_output/
htmlcov/
.pytest_cache/
test-results/
test_results/
playwright-report/
*.lcov

# ── Docker ──
docker-compose.override.yml

# ── Package Manager ──
package-lock.json
!frontend/package-lock.json

# ── Misc ──
*.bak
*.tmp
*.temp
*.orig
.cache/
.parcel-cache/
