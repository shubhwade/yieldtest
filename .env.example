 # MongoDB
 MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/yieldlens?retryWrites=true&w=majority
 
 # Redis
 REDIS_URL=redis://:<password>@redis-host:6379/0
 
 # JWT
 JWT_SECRET=replace_with_random_secret
 
 # External APIs
 GEMINI_API_KEY=
 OPENROUTER_API_KEY=
 NEWS_API_KEY=
 FRED_API_KEY=
 FINNHUB_API_KEY=
 
 # Deployment
 FLASK_ENV=production
 FLASK_DEBUG=False
 FRONTEND_URL=https://your-frontend-domain.com
 BACKEND_URL=https://your-backend-domain.com
 
 # Celery
 CELERY_BROKER_URL=${REDIS_URL}
 CELERY_RESULT_BACKEND=${REDIS_URL}
# ==============================================================================
# YIELDLENS SYSTEM CONFIGURATION TEMPLATE (.env.example)
# ==============================================================================
# Copy this file to .env and configure variables for your active environment.
# DO NOT commit real secrets or API keys to repository history.

# 1. DATA PERSISTENCE & DATABASES
# MongoDB URI for portfolio, watchlist, and user metrics
MONGODB_URI=mongodb://localhost:27017/yieldlens
MONGODB_DB_NAME=yieldlens

# Redis connection URL for high-performance telemetry caching
REDIS_URL=redis://localhost:6379/0

# 2. FINANCIAL DATA APIS (All are optional - fallback systems active when blank)
# Federal Reserve Economic Data (FRED) API Key - https://fred.stlouisfed.org/
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage Market Data API Key - https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub Stock & Bond API Key - https://finnhub.io/
FINNHUB_API_KEY=your_finnhub_key_here

# 3. GLOBAL NEWS SERVICES
# GNews API Key for financial news - https://gnews.io/
GNEWS_API_KEY=your_gnews_key_here

# General NewsAPI Key - https://newsapi.org/
NEWS_API_KEY=your_news_key_here

# 4. ARTIFICIAL INTELLIGENCE & COPILOT
# Google Gemini API Key - https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter rotation model API Key - https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# 5. CORE SECURITY & AUTHENTICATION
# Cryptographic secret for signing JWT access tokens (Change to secure hash)
JWT_SECRET=yieldlens-production-cryptographic-hash-change-immediately
JWT_EXPIRATION_HOURS=24

# 6. APPLICATION SERVERS & NETWORKING
# Flask API Server config
FLASK_PORT=5000
FLASK_DEBUG=False

# Next.js Client config
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
