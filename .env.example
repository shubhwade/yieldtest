# --- DATABASE CONFIGURATION ---
MONGODB_URI=mongodb://localhost:27017/yieldlens
MONGODB_DB_NAME=yieldlens
REDIS_URL=redis://localhost:6379/0

# --- API KEYS (Required for live data) ---
# Federal Reserve Economic Data (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Google Gemini AI (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# --- SERVER CONFIGURATION ---
FLASK_PORT=5000
FLASK_DEBUG=True
JWT_SECRET=generate_a_random_secure_string_here

# --- FRONTEND CONFIGURATION ---
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=http://localhost:5000
