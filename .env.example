# YieldLens Environment Configuration
# Copy this file to .env for local development or .env.local for Next.js
# IMPORTANT: Never commit actual API keys to version control!
# Use secure environment variable management for production (Vercel Secrets, Railway, etc.)

# --- DATABASE CONFIGURATION ---
MONGODB_URI=mongodb://localhost:27017/yieldlens
MONGODB_DB_NAME=yieldlens
REDIS_URL=redis://localhost:6379/0

# --- API KEYS (Required for live data) ---
# Federal Reserve Economic Data (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_key_here

# Google Gemini AI (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_key_here

# Alpha Vantage (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# News API (https://newsapi.org)
NEWS_API_KEY=your_news_api_key_here

# GNews API (https://gnews.io)
GNEWS_API_KEY=your_gnews_key_here

# Finnhub API (https://finnhub.io)
FINNHUB_API_KEY=your_finnhub_key_here

# OpenRouter API (https://openrouter.ai) - Alternative AI provider
OPENROUTER_API_KEY=your_openrouter_key_here

# --- AUTHENTICATION ---
# Generate with: openssl rand -hex 32 or Python: secrets.token_hex(32)
JWT_SECRET=generate_a_random_secure_string_here_at_least_32_characters
JWT_EXPIRATION_HOURS=24

# --- SERVER CONFIGURATION ---
FLASK_PORT=5000
FLASK_DEBUG=False

# --- RATE LIMITING ---
RATE_LIMIT_DEFAULT=200 per day
RATE_LIMIT_AI_QUERY=50 per hour

# --- CACHE TTL (in seconds) ---
FRED_CACHE_TTL=3600
TREASURY_CACHE_TTL=14400
AI_CACHE_TTL=86400

# --- FRONTEND CONFIGURATION ---
# API URL for frontend (must be publicly accessible)
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=http://localhost:5000

